PORT=3000
NODE_ENV=development

# MySQL (phpMyAdmin / XAMPP / WAMP)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=aethelguard
DB_USER=root
DB_PASSWORD=

# Optional connection string (use this instead of individual DB_* values)
# DATABASE_URL="mysql://root:@localhost:3306/aethelguard"

# JWT secret for API authentication (replace with a long random string)
JWT_SECRET=replace-this-with-a-long-random-secret

# Allowed frontend origins for CORS
CORS_ORIGIN=http://localhost:5173

# AES-256 key for Vault (64 hex chars = 32 bytes). Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VAULT_ENCRYPTION_KEY=
